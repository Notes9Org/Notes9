# Supabase URL (same as NEXT_PUBLIC_SUPABASE_URL in your Next.js app)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (same as SUPABASE_SERVICE_ROLE_KEY in your Next.js app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT secret for validating authentication tokens
JWT_SECRET=your-supabase-jwt-secret

# Port for the HTTP/WebSocket server (default: 8080)
PORT=8080

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
