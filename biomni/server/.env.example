# Biomni gateway server
PORT=3002
NODE_ENV=production
BIOMNI_API_KEY=replace-with-random-token
BIOMNI_ALLOWED_ORIGINS=http://localhost:3000
BIOMNI_MAX_REQUEST_BYTES=1048576

# Biomni runtime
BIOMNI_PYTHON_PATH=/opt/biomni_e1/bin/python
BIOMNI_TIMEOUT_SECONDS=1200

# Data path: local folder OR s3://bucket/prefix
BIOMNI_DATA_PATH=s3://your-bucket/biomni-data
BIOMNI_DATA_BUCKET=your-bucket
BIOMNI_DATA_PREFIX=biomni-data/
BIOMNI_S3_LOCAL_CACHE_DIR=/tmp/biomni-data
BIOMNI_S3_CACHE_TTL_SECONDS=900
BIOMNI_S3_SYNC_ON_EVERY_TASK=false
BIOMNI_S3_MAX_FILES=0

# Gemini only
GOOGLE_API_KEY=
BIOMNI_GEMINI_MODEL=gemini-2.5-flash
BIOMNI_GEMINI_REASONING_MODEL=gemini-2.5-pro

# AWS region for S3 APIs
AWS_REGION=us-east-1
