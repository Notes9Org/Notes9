# =============================================================================
# Biomni Server — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── Python / Biomni setup ────────────────────────────────────────────────────
# Path to the Python binary inside the biomni_e1 conda environment.
# Run: conda activate biomni_e1 && which python
#
# macOS / Linux example:
#   BIOMNI_PYTHON_PATH=/opt/miniconda3/envs/biomni_e1/bin/python
# Windows example:
#   BIOMNI_PYTHON_PATH=C:\Users\you\miniconda3\envs\biomni_e1\python.exe
#
# If left unset, falls back to `python` on PATH (must already be biomni_e1).
BIOMNI_PYTHON_PATH=

# Path to the Biomni data lake (~11GB, auto-downloaded on first run).
# Point this at the `data/` directory inside your cloned Biomni repo.
# Example: BIOMNI_DATA_PATH=/home/you/Biomni/data
BIOMNI_DATA_PATH=./data

# Timeout for a single Biomni task (seconds). Complex tasks can take 20+ min.
BIOMNI_TIMEOUT_SECONDS=1200

# ── LLM API Keys (provide at least one) ──────────────────────────────────────
# Groq is recommended: fast, cheap, and works well with Biomni's dual-LLM strategy.
GROQ_API_KEY=

# Anthropic Claude — used for DB-query LLM or reasoning override
ANTHROPIC_API_KEY=

# OpenAI — fallback
OPENAI_API_KEY=

# ── LLM Routing ───────────────────────────────────────────────────────────────
# default_config LLM: handles internal DB / retrieval queries inside Biomni.
# Use a fast, cheap model here.
BIOMNI_DEFAULT_LLM=llama-3.1-8b-instant
BIOMNI_DEFAULT_LLM_SOURCE=Groq

# Reasoning LLM: handles the top-level planning + code-execution loop.
BIOMNI_REASONING_LLM=llama-3.3-70b-versatile
BIOMNI_REASONING_LLM_SOURCE=Groq

# ── Local SGLang server (optional — for fully offline / free inference) ────────
# Run the Biomni-R0-32B model locally via SGLang (requires 2× A100 or 4× A6000).
# python -m sglang.launch_server --model-path biomni/Biomni-R0-32B-Preview \
#   --port 30000 --host 0.0.0.0 --tp 2 --trust-remote-code
#
# Then set:
#   BIOMNI_REASONING_LLM=biomni/Biomni-R0-32B-Preview
#   BIOMNI_REASONING_LLM_SOURCE=Custom
#   BIOMNI_LOCAL_LLM_BASE_URL=http://localhost:30000/v1
BIOMNI_LOCAL_LLM_BASE_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# Bearer token to protect the Biomni server API.
# Set this in production. The Next.js proxy route reads BIOMNI_API_KEY too.
# Leave empty in local dev (no auth required).
BIOMNI_API_KEY=

# Comma-separated list of allowed CORS origins.
# Default: * (allow all — fine for localhost dev)
BIOMNI_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# One-time Python setup (run in a terminal before starting this server):
#
#   git clone https://github.com/snap-stanford/Biomni.git ~/Biomni
#   cd ~/Biomni && bash setup.sh          # creates biomni_e1 conda env
#   conda activate biomni_e1
#   pip install biomni --upgrade
#   # Then set BIOMNI_PYTHON_PATH above and BIOMNI_DATA_PATH to ~/Biomni/data
#
# Start the server:
#   cd biomni/server && pnpm install && pnpm dev
#
# In Next.js root .env.local also add:
#   BIOMNI_SERVER_URL=http://localhost:3002
#   BIOMNI_API_KEY=<same value as above>
# =============================================================================
